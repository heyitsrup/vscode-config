{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder} -B ${workspaceFolder}/build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "problemMatcher": []
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build",
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": "CMake Configure",
            "problemMatcher": ["$gcc"]
        }
    ]
}
